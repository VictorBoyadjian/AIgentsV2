# =============================================================================
# SaaS Agent Team - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================
#
# RAILWAY DEPLOYMENT:
#   The following variables are auto-injected by Railway plugins and should
#   NOT be set manually when deploying on Railway:
#     - PORT             (Railway injects the port for your service)
#     - DATABASE_URL     (Railway PostgreSQL plugin)
#     - REDIS_URL        (Railway Redis plugin)
#     - RAILWAY_PUBLIC_DOMAIN
#     - RAILWAY_PRIVATE_DOMAIN
#     - RAILWAY_ENVIRONMENT
#
#   For Railway, set these as "Shared Variables" in your project so both
#   the app and worker services can access them:
#     - ANTHROPIC_API_KEY, OPENAI_API_KEY (required)
#     - All other API keys and config below
#
# =============================================================================

# --- LLM API Keys (REQUIRED) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxx

# --- LLM Model Configuration ---
ARCHITECT_MODEL=claude-opus-4
PM_MODEL=claude-sonnet-4-5
DEV_MODEL=claude-sonnet-4-5
QA_MODEL=claude-haiku-4-5
SECURITY_MODEL=claude-sonnet-4-5
DEVOPS_MODEL=claude-haiku-4-5
RESEARCH_MODEL=gpt-4o
FALLBACK_MODEL=gpt-4o-mini

# --- Feature Flags ---
ENABLE_PROMPT_CACHING=true
ENABLE_BATCH_API=true
ENABLE_COST_TRACKING=true

# --- Budget Configuration ---
MONTHLY_BUDGET_USD=200.0
DAILY_BUDGET_USD=10.0
WARNING_THRESHOLD=0.70
CRITICAL_THRESHOLD=0.90
EMERGENCY_MODEL_OVERRIDE=gpt-4o-mini
ENABLE_BATCH_BY_DEFAULT=true
CACHE_TTL_SECONDS=3600

# --- Database (local dev only — Railway injects DATABASE_URL automatically) ---
DATABASE_URL=postgresql+asyncpg://saas_agent:password@localhost:5432/saas_agent_db
DATABASE_SYNC_URL=postgresql://saas_agent:password@localhost:5432/saas_agent_db

# --- Redis (local dev only — Railway injects REDIS_URL automatically) ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Weaviate (optional — not available as Railway plugin) ---
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=

# --- GitHub ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxx
GITHUB_ORG=

# --- E2B Code Sandbox ---
E2B_API_KEY=e2b_xxxxxxxxxxxxx

# --- Web Search ---
TAVILY_API_KEY=tvly-xxxxxxxxxxxxx
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxx

# --- Observability ---
LANGSMITH_API_KEY=lsv2_xxxxxxxxxxxxx
LANGSMITH_PROJECT=AIGentsV2
LANGSMITH_TRACING_V2=true

# --- Deployment ---
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=

# --- API Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_CORS_ORIGINS=["http://localhost:3000"]
SECRET_KEY=change-me-in-production-use-a-real-secret-key

# --- Environment ---
# Set to "production" on Railway
ENVIRONMENT=development
